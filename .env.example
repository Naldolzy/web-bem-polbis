APP_NAME="BEM Polbis"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# =========================================
# DATABASE — Supabase PostgreSQL (WAJIB)
# Gunakan "Transaction" pooler (port 6543)
# Dapatkan dari: Supabase > Project > Settings > Database > Connection Pooling
# =========================================
DB_CONNECTION=pgsql
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# =========================================
# STORAGE — Supabase S3 (WAJIB UNTUK VERCEL)
# Supabase > Project Settings > Storage > S3 Access Keys
# =========================================
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=YOUR_SUPABASE_S3_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SUPABASE_S3_SECRET_KEY
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=bem-media
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
# AWS_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/bem-media

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
